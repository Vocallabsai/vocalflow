<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Merged with Xcode's generated Info.plist (GENERATE_INFOPLIST_FILE=YES).
	     The vocalflow:// scheme is how the keyboard opens the app to dictate. -->
	<!-- Keeps the mic + Deepgram stream alive after we bounce back to the host
	     app — the whole point of the background-dictation flow. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>vocallabsai.VocalFlow</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>vocalflow</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
