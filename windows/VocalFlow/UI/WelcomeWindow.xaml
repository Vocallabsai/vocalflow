<Window x:Class="VocalFlow.UI.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to VocalFlow"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        FontFamily="{StaticResource AppFont}"
        ResizeMode="NoResize">
    <StackPanel Margin="28">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="🎙" FontSize="22" VerticalAlignment="Center" />
            <TextBlock Text="Welcome to VocalFlow" FontSize="20" FontWeight="SemiBold"
                       Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="Hold a hotkey, speak, and your words are typed into any text field."
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
        <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,18" />

        <StackPanel Margin="0,0,0,14">
            <TextBlock FontWeight="Medium" Text="1.  Add a Deepgram API key" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"
                       Text="Required for transcription. Free tier available." />
            <TextBlock Margin="0,3,0,0">
                <Hyperlink NavigateUri="https://console.deepgram.com/signup" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentHoverBrush}">
                    Get Deepgram key →
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Margin="0,0,0,14">
            <TextBlock FontWeight="Medium" Text="2.  Optional: add an LLM key" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"
                       Text="Enables spelling and grammar fixes, code-mix input, and translation." />
            <TextBlock Margin="0,3,0,0">
                <Hyperlink NavigateUri="https://console.groq.com/keys" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentHoverBrush}">Groq →</Hyperlink>
                <Run Text="    " />
                <Hyperlink NavigateUri="https://openrouter.ai/keys" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentHoverBrush}">OpenRouter →</Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Margin="0,0,0,14">
            <TextBlock FontWeight="Medium" Text="3.  Paste keys into Settings" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"
                       Text="Find Settings any time via the mic icon in the system tray." />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Maybe later" MinWidth="96" Margin="0,0,8,0" Padding="12,6" Click="OnMaybeLater" />
            <Button Content="Open Settings" MinWidth="120" Padding="14,6" IsDefault="True"
                    Style="{StaticResource AccentButton}" Click="OnOpenSettings" />
        </StackPanel>
    </StackPanel>
</Window>
