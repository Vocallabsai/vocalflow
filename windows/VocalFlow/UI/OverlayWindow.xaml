<Window x:Class="VocalFlow.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="BarStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="4" />
            <Setter Property="Height" Value="6" />
            <Setter Property="RadiusX" Value="2" />
            <Setter Property="RadiusY" Value="2" />
            <Setter Property="Fill" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" Padding="18,10" Background="#EC0C0714"
            BorderBrush="#808400FF" BorderThickness="1">
        <StackPanel Orientation="Horizontal">
            <StackPanel x:Name="Bars" Orientation="Horizontal" VerticalAlignment="Center">
                <Rectangle x:Name="Bar1" Style="{StaticResource BarStyle}" Margin="0,0,5,0" />
                <Rectangle x:Name="Bar2" Style="{StaticResource BarStyle}" Margin="0,0,5,0" />
                <Rectangle x:Name="Bar3" Style="{StaticResource BarStyle}" Margin="0,0,5,0" />
                <Rectangle x:Name="Bar4" Style="{StaticResource BarStyle}" />
            </StackPanel>
            <TextBlock x:Name="TranscriptText"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontSize="13"
                       MaxWidth="360"
                       TextTrimming="WordEllipsis"
                       Visibility="Collapsed" />
        </StackPanel>
    </Border>
</Window>
