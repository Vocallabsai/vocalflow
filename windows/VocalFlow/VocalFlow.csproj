<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>VocalFlow</AssemblyName>
    <RootNamespace>VocalFlow</RootNamespace>
    <Version>1.3.0</Version>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

  <!-- TypeOverWatcher reads/observes the focused text field via System.Windows.Automation (the
       Windows analog of the macOS Accessibility API). UIAutomationClient/UIAutomationTypes ship in
       the Windows Desktop framework pack already referenced via UseWPF, so no extra reference is
       needed here. -->


</Project>
